            <Image url="@../imagens/background_loja.png" />
         </image>
      </ImageView>
      
      <Label fx:id="labelyen" layoutX="425.0" layoutY="114.0" style="-fx-font-size: 22px; -fx-text-fill: #ffd700; -fx-font-weight: bold;" text="0" />
      
      <VBox fx:id="painelItens" layoutX="140.0" layoutY="190.0" prefHeight="290.0" prefWidth="520.0" spacing="12.0" alignment="TOP_CENTER" />
      
      <Label fx:id="labelaviso" layoutX="150.0" layoutY="470.0" prefWidth="500.0" alignment="CENTER" style="-fx-text-fill: #ff6666; -fx-font-size: 16px; -fx-font-weight: bold;" text="" />

      <Button layoutX="140.0" layoutY="505.0" mnemonicParsing="false" onAction="#mostrarPocoes" prefHeight="65.0" prefWidth="160.0" opacity="0.0" style="-fx-cursor: hand;" />
      <Button layoutX="315.0" layoutY="505.0" mnemonicParsing="false" onAction="#mostrarMagias" prefHeight="65.0" prefWidth="160.0" opacity="0.0" style="-fx-cursor: hand;" />
      <Button layoutX="495.0" layoutY="505.0" mnemonicParsing="false" onAction="#acaovoltarondas" prefHeight="65.0" prefWidth="180.0" opacity="0.0" style="-fx-cursor: hand;" />
      
      <Button layoutX="680.0" layoutY="50.0" mnemonicParsing="false" onAction="#acaovoltarondas" prefHeight="45.0" prefWidth="45.0" opacity="0.0" style="-fx-cursor: hand;" />
   </children>
</AnchorPane>