<?xml version="1.0" encoding="utf-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UpgradeController">
   <children>
      <Button layoutX="20.0" layoutY="20.0" onAction="#acaovoltar" text="voltar" />
      <VBox alignment="CENTER" layoutX="150.0" layoutY="30.0" prefWidth="500.0" spacing="15.0">
         <children>
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="upgrades e status" />
            
            <Label fx:id="labelpontos" style="-fx-font-size: 18px; -fx-text-fill: purple;" text="pontos demoniacos: 0" />
            <Label fx:id="labelcusto" style="-fx-font-size: 14px;" text="custo para subir de nivel: 100 pontos" />
            <Button onAction="#uparnivel" prefHeight="40.0" prefWidth="250.0" style="-fx-font-weight: bold;" text="comprar nivel (+8 pontos)" />
            <Label fx:id="labelaviso" style="-fx-text-fill: red;" text="" />
            
            <VBox spacing="10.0" style="-fx-background-color: #f0f0f0; -fx-padding: 15;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="--- seus status atuais ---" />
                  <Label fx:id="labelstatus" text="nivel: 1\nhp: 100\natf: 1\natm: 1\ndefesa: 1/80" />
               </children>
            </VBox>
            
            <Label fx:id="labelpontosdistribuir" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: blue;" text="pontos para distribuir: 0" />
            <Label text="escolha onde alocar os seus pontos (custa 1 ponto cada):" />
            <HBox alignment="CENTER" spacing="10.0">
                <children>
                    <Button onAction="#uparhp" prefWidth="110.0" text="+ hp (10 vida)" />
                    <Button onAction="#uparatf" prefWidth="110.0" text="+ at.f (1 pto)" />
                    <Button onAction="#uparatm" prefWidth="110.0" text="+ at.m (1 pto)" />
                    <Button onAction="#upardefesa" prefWidth="110.0" text="+ def (1%)" />
                </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>