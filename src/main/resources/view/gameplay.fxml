<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GameController">
   <children>
      <VBox layoutX="50.0" layoutY="50.0" prefHeight="500.0" prefWidth="700.0" spacing="20.0">
         <children>
            <HBox spacing="50.0">
               <children>
                  <Label fx:id="labelonda" style="-fx-font-size: 24px;" text="onda: 1" />
                  <Label fx:id="labelvidaplayer" style="-fx-font-size: 24px;" text="vida: 1000" />
                  <Button fx:id="btninventario" mnemonicParsing="false" onAction="#abririnventario" text="abrir inventario" />
               </children>
            </HBox>
            <TextArea fx:id="textlogbatalha" editable="false" prefHeight="300.0" prefWidth="700.0" style="-fx-font-size: 16px;" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnataquebasico" mnemonicParsing="false" onAction="#acaoataquebasico" prefHeight="50.0" prefWidth="150.0" text="ataque basico" />
                  <Button fx:id="btnataqueespecial" mnemonicParsing="false" onAction="#acaoataqueespecial" prefHeight="50.0" prefWidth="150.0" text="ataque especial" />
                  <Button fx:id="btnhabilidade1" mnemonicParsing="false" onAction="#acaohabilidade1" prefHeight="50.0" prefWidth="150.0" text="habilidade temporal" />
                  <Button fx:id="btnhabilidade2" mnemonicParsing="false" onAction="#acaohabilidade2" prefHeight="50.0" prefWidth="150.0" text="habilidade suprema" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>