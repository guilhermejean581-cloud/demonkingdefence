<?xml version="1.0" encoding="utf-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: black;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MenuController">
   <children>
      <ImageView fitHeight="600.0" fitWidth="800.0" opacity="0.6" pickOnBounds="true">
         <image>
            <Image url="@../imagens/background_menu.png" />
         </image>
      </ImageView>
      <VBox alignment="TOP_CENTER" spacing="5.0" style="-fx-padding: 30 0 0 0;">
         <children>
            <ImageView fitHeight="200.0" fitWidth="600.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../imagens/logo.png" />
               </image>
            </ImageView>
            <VBox alignment="CENTER" spacing="12.0">
               <children>
                  <Button fx:id="btnjogar" mnemonicParsing="false" onAction="#acaojogar" styleClass="image-button">
                     <graphic>
                        <ImageView fitHeight="60.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../imagens/btn_jogar.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="btnranking" mnemonicParsing="false" onAction="#acaoranking" styleClass="image-button">
                     <graphic>
                        <ImageView fitHeight="60.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../imagens/btn_ranking.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="btncreditos" mnemonicParsing="false" onAction="#acaocreditos" styleClass="image-button">
                     <graphic>
                        <ImageView fitHeight="60.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../imagens/btn_creditos.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="btnencerrar" mnemonicParsing="false" onAction="#acaoencerrar" styleClass="image-button">
                     <graphic>
                        <ImageView fitHeight="60.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../imagens/btn_encerrar.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>