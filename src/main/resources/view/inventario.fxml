<?xml version="1.0" encoding="utf-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InventarioController">
   <children>
      <Button layoutX="20.0" layoutY="20.0" onAction="#acaovoltar" text="voltar" />
      <VBox alignment="CENTER" layoutX="150.0" layoutY="30.0" prefWidth="500.0" spacing="10.0">
         <children>
            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="inventario" />
            
            <VBox spacing="8.0" style="-fx-background-color: #f0f0f0; -fx-padding: 12; -fx-alignment: center;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="--- status e evolucao ---" />
                  <Label fx:id="labelnivelxp" text="nivel: 1" />
                  <Label fx:id="labelyen" text="pontos demoniacos: 0 | disponiveis: 0" />
                  
                  <VBox spacing="5.0" fillWidth="false" style="-fx-alignment: center;">
                     <children>
                        <HBox spacing="15.0" alignment="CENTER">
                           <children>
                              <Label fx:id="labelhp" text="hp: 50" prefWidth="120.0" />
                              <Button onAction="#acaomaishp" text="+" style="-fx-font-weight: bold;" />
                           </children>
                        </HBox>
                        <HBox spacing="15.0" alignment="CENTER">
                           <children>
                              <Label fx:id="labelatf" text="atf: 1" prefWidth="120.0" />
                              <Button onAction="#acaomaisatf" text="+" style="-fx-font-weight: bold;" />
                           </children>
                        </HBox>
                        <HBox spacing="15.0" alignment="CENTER">
                           <children>
                              <Label fx:id="labelatm" text="atm: 1" prefWidth="120.0" />
                              <Button onAction="#acaomaisatm" text="+" style="-fx-font-weight: bold;" />
                           </children>
                        </HBox>
                        <HBox spacing="15.0" alignment="CENTER">
                           <children>
                              <Label fx:id="labeldefesa" text="defesa: 1%" prefWidth="120.0" />
                              <Button onAction="#acaomaisdefesa" text="+" style="-fx-font-weight: bold;" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <Button fx:id="btnSubirNivel" onAction="#acaosubirnivel" text="subir nivel" />
               </children>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: #e0e0e0; -fx-padding: 15; -fx-alignment: center;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="--- equipamentos e magias ---" />
                  <Label fx:id="labelslot1" text="arma: vazio" />
                  <Label fx:id="labelslot2" text="m1: vazio | m2: vazio" />
                  <HBox spacing="10.0" alignment="CENTER">
                     <children>
                        <Button onAction="#acaoequipararma" text="equipar arma" />
                        <Button onAction="#acaoequiparmagia1" text="equipar magia 1" />
                        <Button onAction="#acaoequiparmagia2" text="equipar magia 2" />
                     </children>
                  </HBox>
                  <Button fx:id="btnDesbloquearEspecial" onAction="#acaodesbloquearespecial" text="desbloquear especial" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>