<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InventarioController">
   <children>
      <Button layoutX="20.0" layoutY="20.0" onAction="#acaovoltar" text="Voltar" />
      
      <VBox alignment="CENTER" layoutX="150.0" layoutY="60.0" prefWidth="500.0" spacing="20.0">
         <children>
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold;" text="INVENTÁRIO" />
            
            <VBox spacing="10.0" style="-fx-background-color: #f0f0f0; -fx-padding: 15;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="--- STATUS ---" />
                  <Label fx:id="labelNivelXp" text="Nível: 1 (XP: 0/100)" />
                  <Label fx:id="labelYen" text="Dinheiro: 0 Yen" />
               </children>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: #e0e0e0; -fx-padding: 15;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="--- MAGIAS (Clique para equipar) ---" />
                  <Button onAction="#clicarBolaDeFogo" prefWidth="200.0" text="Bola de Fogo" />
               </children>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: #d0d0d0; -fx-padding: 15;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="--- SLOTS EQUIPADOS ---" />
                  <Label fx:id="labelSlot1" text="Slot 1: vazio" />
                  <Label fx:id="labelSlot2" text="Slot 2: vazio" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>