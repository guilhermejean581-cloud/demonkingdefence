<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InventarioController">
   <children>
      <ImageView fitHeight="600.0" fitWidth="800.0" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@../imagens/background_inventario.png" />
         </image>
      </ImageView>

      <Button layoutX="145.0" layoutY="85.0" mnemonicParsing="false" onAction="#acaovoltar" prefHeight="35.0" prefWidth="95.0" style="-fx-background-color: rgba(0,0,0,0.02); -fx-cursor: hand;" />
      
      <VBox alignment="CENTER" layoutX="150.0" layoutY="130.0" prefHeight="200.0" prefWidth="500.0" spacing="8.0">
         <children>
            <Label style="-fx-text-fill: #bfa780; -fx-font-weight: bold; -fx-font-size: 14px;" text="-- status e evolucao --" />
            <Label fx:id="labelnivelxp" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="nivel: 1" />
            <Label fx:id="labelyen" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="pontos demoniacos: 0 | pontos para distribuir: 0" />
            <Button mnemonicParsing="false" onAction="#acaomaishp" prefHeight="25.0" prefWidth="25.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 3; -fx-text-fill: #bfa780; -fx-font-weight: bold; -fx-cursor: hand;" text="+" />
            
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label fx:id="labelhp" alignment="CENTER_RIGHT" prefWidth="120.0" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="hp: 50" />
               </children>
            </HBox>

            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label fx:id="labelatf" alignment="CENTER_RIGHT" prefWidth="120.0" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="atf: 1" />
                  <Button mnemonicParsing="false" onAction="#acaomaisatf" prefHeight="25.0" prefWidth="25.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 3; -fx-text-fill: #bfa780; -fx-font-weight: bold; -fx-cursor: hand;" text="+" />
               </children>
            </HBox>

            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label fx:id="labelatm" alignment="CENTER_RIGHT" prefWidth="120.0" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="atm: 1" />
                  <Button mnemonicParsing="false" onAction="#acaomaisatm" prefHeight="25.0" prefWidth="25.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 3; -fx-text-fill: #bfa780; -fx-font-weight: bold; -fx-cursor: hand;" text="+" />
               </children>
            </HBox>

            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label fx:id="labeldefesa" alignment="CENTER_RIGHT" prefWidth="120.0" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="defesa: 1%" />
                  <Button mnemonicParsing="false" onAction="#acaomaisdefesa" prefHeight="25.0" prefWidth="25.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 3; -fx-text-fill: #bfa780; -fx-font-weight: bold; -fx-cursor: hand;" text="-" />
               </children>
            </HBox>

            <Button mnemonicParsing="false" onAction="#acaosubirnivel" prefHeight="30.0" prefWidth="240.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 5; -fx-text-fill: #bfa780; -fx-cursor: hand;" text="subir nivel (custo: 100 pontos)" />
         </children>
      </VBox>

      <VBox alignment="CENTER" layoutX="150.0" layoutY="350.0" prefHeight="150.0" prefWidth="500.0" spacing="10.0">
         <children>
            <Label style="-fx-text-fill: #bfa780; -fx-font-weight: bold; -fx-font-size: 14px;" text="-- equipamentos e magias --" />
            
            <Label fx:id="labelslot1" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="arma: espada antiga" />
            <Label fx:id="labelslot2" style="-fx-text-fill: #bfa780; -fx-font-size: 14px;" text="m1: bola de fogo | m2: vazio" />
            
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#acaoequipararma" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 5; -fx-text-fill: #bfa780; -fx-cursor: hand;" text="equipar arma" />
                  <Button mnemonicParsing="false" onAction="#acaoequiparmagia1" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 5; -fx-text-fill: #bfa780; -fx-cursor: hand;" text="equipar magia 1" />
                  <Button mnemonicParsing="false" onAction="#acaoequiparmagia2" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 5; -fx-text-fill: #bfa780; -fx-cursor: hand;" text="equipar magia 2" />
               </children>
            </HBox>
            
            <Button mnemonicParsing="false" onAction="#acaodesbloquearespecial" prefHeight="30.0" prefWidth="280.0" style="-fx-background-color: transparent; -fx-border-color: #554433; -fx-border-radius: 5; -fx-text-fill: #bfa780; -fx-cursor: hand;" text="desbloquear especial (custo: 200 pontos)" />
         </children>
      </VBox>
   </children>
</AnchorPane>
