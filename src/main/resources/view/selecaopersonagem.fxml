<?xml version="1.0" encoding="utf-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SelecaoPersonagemController">
   <children>
      <VBox alignment="CENTER" layoutX="200.0" layoutY="50.0" prefHeight="500.0" prefWidth="400.0" spacing="15.0">
         <children>
            <Label style="-fx-font-size: 24px;" text="selecionar heroi" />
            
            <HBox fx:id="layoutSlot1" alignment="CENTER" spacing="10.0">
               <children>
                  <Button fx:id="btnSlot1" mnemonicParsing="false" onAction="#acaoSlot1" prefHeight="60.0" prefWidth="300.0" textAlignment="CENTER" />
                  <Button fx:id="btnDeletar1" mnemonicParsing="false" onAction="#acaoDeletar1" prefHeight="60.0" prefWidth="50.0" text="🗑" />
               </children>
            </HBox>

            <HBox fx:id="layoutSlot2" alignment="CENTER" spacing="10.0">
               <children>
                  <Button fx:id="btnSlot2" mnemonicParsing="false" onAction="#acaoSlot2" prefHeight="60.0" prefWidth="300.0" textAlignment="CENTER" />
                  <Button fx:id="btnDeletar2" mnemonicParsing="false" onAction="#acaoDeletar2" prefHeight="60.0" prefWidth="50.0" text="🗑" />
               </children>
            </HBox>

            <HBox fx:id="layoutSlot3" alignment="CENTER" spacing="10.0">
               <children>
                  <Button fx:id="btnSlot3" mnemonicParsing="false" onAction="#acaoSlot3" prefHeight="60.0" prefWidth="300.0" textAlignment="CENTER" />
                  <Button fx:id="btnDeletar3" mnemonicParsing="false" onAction="#acaoDeletar3" prefHeight="60.0" prefWidth="50.0" text="🗑" />
               </children>
            </HBox>

            <HBox fx:id="layoutSlot4" alignment="CENTER" spacing="10.0">
               <children>
                  <Button fx:id="btnSlot4" mnemonicParsing="false" onAction="#acaoSlot4" prefHeight="60.0" prefWidth="300.0" textAlignment="CENTER" />
                  <Button fx:id="btnDeletar4" mnemonicParsing="false" onAction="#acaoDeletar4" prefHeight="60.0" prefWidth="50.0" text="🗑" />
               </children>
            </HBox>

            <Button fx:id="btnCriarPersonagem" mnemonicParsing="false" onAction="#acaoCriarPersonagem" prefHeight="40.0" prefWidth="300.0" text="criar personagem" />
            <Button mnemonicParsing="false" onAction="#acaoVoltar" prefHeight="40.0" prefWidth="300.0" text="voltar" />
         </children>
      </VBox>
   </children>
</AnchorPane>