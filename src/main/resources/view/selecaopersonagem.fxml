<?xml version="1.0" encoding="utf-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SelecaoPersonagemController">
   <children>
      <VBox alignment="CENTER" layoutX="250.0" layoutY="100.0" prefHeight="400.0" prefWidth="300.0" spacing="20.0">
         <children>
            <Label style="-fx-font-size: 24px;" text="selecionar heroi" />
            <Button fx:id="btnSlot1" mnemonicParsing="false" onAction="#acaoSlot1" prefHeight="40.0" prefWidth="300.0" text="slot 1" />
            <Button fx:id="btnSlot2" mnemonicParsing="false" onAction="#acaoSlot2" prefHeight="40.0" prefWidth="300.0" text="slot 2" />
            <Button fx:id="btnSlot3" mnemonicParsing="false" onAction="#acaoSlot3" prefHeight="40.0" prefWidth="300.0" text="slot 3" />
            <Button fx:id="btnSlot4" mnemonicParsing="false" onAction="#acaoSlot4" prefHeight="40.0" prefWidth="300.0" text="slot 4" />
            <Button mnemonicParsing="false" onAction="#acaodeletar" prefHeight="40.0" prefWidth="300.0" text="deletar heroi" />
            <Button mnemonicParsing="false" onAction="#acaoVoltar" prefHeight="40.0" prefWidth="300.0" text="voltar" />
         </children>
      </VBox>
   </children>
</AnchorPane>